# ─────────────────────────────────────────────────────────────
#  Microsoft Graph API — Credenciais Azure AD
#  Portal: https://portal.azure.com → App registrations
# ─────────────────────────────────────────────────────────────

# ID do seu tenant Azure (ex: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
TENANT_ID=seu_tenant_id_aqui

# ID do app registrado no Azure AD
CLIENT_ID=seu_client_id_aqui

# Secret do app (Azure → App registrations → Certificates & secrets)
# Deixe em branco para usar autenticação via Device Code Flow (login no browser)
CLIENT_SECRET=seu_client_secret_aqui

# Modo de auth: "client_credentials" (app-only) ou "device_code" (login usuário)
# - client_credentials: precisa de CLIENT_SECRET, acessa arquivos via SharePoint/Sites
# - device_code: abre link no browser, acessa OneDrive do usuário logado
AUTH_MODE=device_code

# (Apenas para client_credentials) ID do site SharePoint ou drive
# Deixe vazio se usar device_code
SHAREPOINT_SITE_ID=

# Caminho padrão para salvar sessão de token (não commitar!)
TOKEN_CACHE_PATH=.token_cache.json
